{
    "id": "de.dakosy.enhanced-emojis",
    "name": "Enhanced Emojis",
    "version": "0.1.0",
    "description": "Enhances the display of custom emojis in Mattermost.",
    "homepage_url": "https://github.com/marcgoertzen/enhanced-emojis",
    "support_url": "https://github.com/marcgoertzen/enhanced-emojis/issues",
    "icon_path": "assets/enhanced_emojis_icon.png",

    "min_server_version": "10.0.0",
    "settings_schema": {
        "header": "",
        "footer": "",
        "settings": [
            {
                "key": "EnableEnhancedEmojis",
                "display_name": "Enable Enhanced Emojis",
                "type": "bool",
                "help_text": "Enable larger custom emojis in Mattermost post content.",
                "placeholder": "",
                "default": true
            },
            {
                "key": "EnableDeveloperMode",
                "display_name": "Enable Developer Mode",
                "type": "bool",
                "help_text": "Enables visual debugging features for Enhanced Emojis.",
                "placeholder": "",
                "default": false
            },
            {
                "key": "EmojiSize",
                "display_name": "Emoji Size",
                "type": "dropdown",
                "help_text": "Select the size used for custom emojis in post content.",
                "placeholder": "",
                "default": "default",
                "options": [
                    {
                        "display_name": "Small (24px)",
                        "value": "small"
                    },
                    {
                        "display_name": "Default (32px)",
                        "value": "default"
                    },
                    {
                        "display_name": "Large (48px)",
                        "value": "large"
                    },
                    {
                        "display_name": "Extra Large (64px)",
                        "value": "extraLarge"
                    }
                ]
            }
        ]
    },
    "server": {
        "executable": "server/dist/enhanced-emojis-windows-amd64.exe",
        "executables": {
            "linux-amd64": "server/dist/enhanced-emojis-linux-amd64",
            "darwin-amd64": "server/dist/enhanced-emojis-darwin-amd64",
            "windows-amd64": "server/dist/enhanced-emojis-windows-amd64.exe"
        }
    },

    "webapp": {
        "bundle_path": "webapp/dist/main.js"
    }
}
